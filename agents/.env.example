# Root .env.compose is canonical. Use this only for direct worker runs.
APP_ENV=development
APP_DEV_MODE=true
REDIS_URL=redis://localhost:6379/0
BACKEND_API_URL=http://localhost:54800
WORKER_CALLBACK_SECRET=resume-builder-local-worker-secret
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
EXTRACTION_AGENT_MODEL=
EXTRACTION_AGENT_FALLBACK_MODEL=
GENERATION_AGENT_MODEL=openai/gpt-5-mini
GENERATION_AGENT_FALLBACK_MODEL=google/gemini-flash-1.5
GENERATION_AGENT_REASONING_EFFORT=none
VALIDATION_AGENT_MODEL=
VALIDATION_AGENT_FALLBACK_MODEL=
