# Canonical local env for Compose and local app defaults
COMPOSE_PROJECT_NAME=resume-builder

# Host port override if occupied locally
FRONTEND_PORT=5173
BACKEND_HOST_PORT=54800
SUPABASE_GATEWAY_PORT=54421
SUPABASE_DB_HOST_PORT=54423

# Required local secrets
POSTGRES_PASSWORD=resume-builder-local-postgres-password
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters
WORKER_CALLBACK_SECRET=resume-builder-local-worker-secret
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InJlc3VtZS1idWlsZGVyLWxvY2FsIiwiaWF0IjoxNzAwMDAwMDAwLCJleHAiOjE4OTM0NTYwMDAsImF1ZCI6ImF1dGhlbnRpY2F0ZWQifQ.IzSCouwdqbP706EVRmz9-xXIk9OWq4dZOTZqmJEXjCY
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoicmVzdW1lLWJ1aWxkZXItbG9jYWwiLCJpYXQiOjE3MDAwMDAwMDAsImV4cCI6MTg5MzQ1NjAwMCwiYXVkIjoiYXV0aGVudGljYXRlZCJ9.U0gL6BI4nEOFY_DdddWDAxb50XO_-5pau-GKC8UR-EA

# Browser-facing local URLs
APP_URL=http://localhost:5173
API_URL=http://localhost:54800
SUPABASE_URL=http://localhost:54421
SUPABASE_INTERNAL_URL=http://supabase-kong:8000

# Shared runtime toggle
APP_ENV=development
DEV_MODE=true
DUPLICATE_SIMILARITY_THRESHOLD=85

# Per-agent OpenRouter config
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CLEANUP_MODEL=openai/gpt-4o-mini
EXTRACTION_AGENT_MODEL=minimax/minimax-m2.7
EXTRACTION_AGENT_FALLBACK_MODEL=openai/gpt-5-mini
GENERATION_AGENT_MODEL=openai/gpt-5-mini
GENERATION_AGENT_FALLBACK_MODEL=google/gemini-flash-1.5
GENERATION_AGENT_REASONING_EFFORT=none
VALIDATION_AGENT_MODEL=minimax/minimax-m2.7
VALIDATION_AGENT_FALLBACK_MODEL=openai/gpt-5-mini

# Leave key and from blank when email is off
EMAIL_NOTIFICATIONS_ENABLED=false
RESEND_API_KEY=
EMAIL_FROM=
ADMIN_EMAILS=
INVITE_LINK_EXPIRY_HOURS=168

# Local seed user
LOCAL_DEV_USER_EMAIL=invite-only@example.com
LOCAL_DEV_USER_PASSWORD=ChangeMe123!
LOCAL_DEV_USER_IS_ADMIN=true
